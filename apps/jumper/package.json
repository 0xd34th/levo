  "scripts": {
    "analyze:bundle:experimental": "pnpm next experimental-analyze",
    "analyze:bundle": "ANALYZE=true pnpm build",
    "dev": "next dev --turbopack",
    "dev:local": "dotenv -e .env.localhost next dev",
    "dev:staging": "dotenv -e .env.staging next dev",
    "dev:production": "dotenv -e .env.production next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=6144 next build --turbopack && node ./scripts/prepare-standalone.mjs",
    "api": "./gen-api.sh",
    "start": "node --env-file=.env ./.next/standalone/apps/jumper/server.js",
    "lint": "eslint .",
    "lint_es": "eslint . --ext .ts,.tsx,.js,.jsx",
    "preview": "next preview",
    "clean": "rm -rf ./tsconfig.tsbuildinfo",
    "lint-staged": "lint-staged",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "fix:staged-files": "lint-staged --allow-empty",
    "fix:all-files": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "pre-commit": "lint-staged",
    "i18next-resources-for-ts": "i18next-resources-for-ts interface -i ./src/i18n/translations/en -o ./src/i18n/resources.d.ts",
    "test": "pnpm test:unit",
    "test:install": "pnpm exec playwright install",
    "test:qase": "QASE_MODE=testops pnpm test",
    "test:e2e-real": "npx playwright test --headed",
    "test:ci:e2e": "npx playwright test",
    "test:ci:e2e:qase": "QASE_MODE=testops npx playwright test",
    "test:unit": "vitest run --project=unit",
    "test:snapshots": "vitest run --project=snapshots",
    "test:snapshots:generate": "vitest run --project=snapshots -u",
    "test:storybook": "vitest run --project=storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "debug": "NODE_OPTIONS='--inspect' next dev"
  },
  "lint-staged": {
    "**/*.(ts|tsx|js|mjs)": [
      "bash -c tsc --noEmit",
      "pnpm eslint --fix",
      "pnpm prettier --write"
    ],
    "**/*.(md|json)": [
      "pnpm prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
