# BlockVision (Sui Indexing API + RPC)
# Free trial: 30 calls/day —— Day 1 缓存层为硬约束
SUIVISION_API_KEY=your_blockvision_key
# 索引 API base（注意是 api.blockvision.org，非 RPC）
BLOCKVISION_API_URL=https://api.blockvision.org/v2/sui
# Sui JSON-RPC（BlockVision RPC 网关或 Mysten 官方）
SUI_RPC_URL=https://sui-mainnet.blockvision.org/v1
# 兜底 RPC：BV 配额耗尽时仍能解析 coin metadata；缺省走 Mysten 官方公共节点（始终可用）
SUI_RPC_PUBLIC_FALLBACK=https://fullnode.mainnet.sui.io:443
# 服务端可独立设置，缺省回落到 SUI_RPC_URL
NEXT_PUBLIC_SUI_NETWORK=mainnet

# DeepSeek（必填）
DEEPSEEK_API_KEY=
# 自托管或代理时填；缺省走官方 https://api.deepseek.com
DEEPSEEK_BASE_URL=
# 当前只跑 fast 档，对应这个模型 ID
DEFAULT_PROVIDER=deepseek-chat

# Upstash Redis（可选；缺省走内存兜底，仅本地开发可用）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# MCP 客户端配置（可选）— JSON 数组：[{"name":"foo","transport":{"type":"sse","url":"...","headers":{...}}}]
MCP_SERVERS=
MCP_TIMEOUT_MS=3000

# 配额上限（per-day per-fingerprint）
DAILY_FREE_MESSAGES=10
DAILY_FREE_BV_CALLS=200

# Stripe（v2，MVP 可留空）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PostHog（可选）
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cloudflare Turnstile（可选）
TURNSTILE_SECRET=
NEXT_PUBLIC_TURNSTILE_SITEKEY=
