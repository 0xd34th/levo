ENCLAVE_REGISTRY_ID=0x<levo-mainnet-enclave-registry-id>
NAUTILUS_SIGNER_EXPECTED_PUBLIC_KEY=0x<nautilus-mainnet-public-key>

# Must match apps/web/.env
NAUTILUS_SIGNER_SECRET="replace-me"
NAUTILUS_SIGNER_SEED_BASE64="replace-me"
