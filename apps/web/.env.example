# Database
DATABASE_URL="postgresql://<user>:<password>@localhost:5432/<database>"

# Redis
REDIS_URL="redis://localhost:6379"

# twitterapi.io
TWITTER_API_KEY="replace-me"

# HMAC secret for quote tokens and mandate tx intents (generate with: openssl rand -hex 32)
HMAC_SECRET="replace-with-64-hex-characters-from-openssl-rand-hex-32"

# Privy (X/Twitter login)
NEXT_PUBLIC_PRIVY_APP_ID="replace-me"
PRIVY_APP_SECRET="replace-me"

# Canonical same-origin base URL used by production API origin checks and links.
APP_ORIGIN="http://localhost:3000"

# Sponsor gas station signer. Fund the derived address balance with SUI for
# address-balance gas; legacy Coin<SUI> fallback remains supported.
# Check sponsor health: pnpm --dir apps/web gas-station:status
# Merge fragmented fallback SUI coins during a quiet period: pnpm --dir apps/web gas-station:merge
GAS_STATION_SECRET_KEY="replace-me"

# StableLayer manager signer for service-side Earn yield settlement
# Base64-encoded 32-byte Ed25519 seed. Required for real Claim / auto-settle Withdraw yield.
STABLE_LAYER_MANAGER_SECRET_KEY="replace-me"

# Sui
NEXT_PUBLIC_SUI_NETWORK="mainnet"
SUI_RPC_URL="https://fullnode.mainnet.sui.io:443"
# Public fallback used by Sui explorer tools when a paid/rate-limited gateway is unavailable.
SUI_RPC_PUBLIC_FALLBACK="https://fullnode.mainnet.sui.io:443"
# Optional public JSON allowlist appended after built-in USDC and SUI for Send and Swap.
# Built-ins win on duplicate coinType values; malformed entries are ignored at runtime.
NEXT_PUBLIC_SEND_COIN_OPTIONS='[{"coinType":"0x...::module::COIN","label":"COIN","decimals":6,"inputDecimals":6,"caption":"Token","iconSrc":"/sui.svg"}]'

# Sui explorer chat data providers (server-only)
SUIVISION_API_KEY="replace-me"
BLOCKVISION_API_URL="https://api.blockvision.org/v2/sui"

# OKX OnchainOS V6 adapters. Disabled by default; credentials stay server-only.
OKX_API_KEY=""
OKX_SECRET_KEY=""
OKX_API_PASSPHRASE=""
OKX_PROJECT_ID=""
OKX_BASE_URL="https://web3.okx.com"
OKX_SWAP_ENABLED="false"
OKX_FALLBACK_ENABLED="false"
OKX_BRIDGE_ENABLED="false"

# Optional MCP bridge registry for chat tools. Empty means zero MCP startup work.
MCP_SERVERS=""
MCP_TIMEOUT_MS="3000"

# Fill these with your current mainnet deploy outputs
NEXT_PUBLIC_PACKAGE_ID="0x<levo-mainnet-package-id>"
# Keep the public copy in sync so browser-side balance display can map LEVO_USD to USDC.
NEXT_PUBLIC_LEVO_USD_COIN_TYPE="0x<standalone-levo-usd-package-id>::levo_usd::LEVO_USD"
LEVO_USD_COIN_TYPE="0x<standalone-levo-usd-package-id>::levo_usd::LEVO_USD"

# Levo Agent (agentic wallet — mandate Move package)
# Agent flows are testnet-anchored regardless of NEXT_PUBLIC_SUI_NETWORK above.
# v2 testnet PackageID: 0x17546269c14c25aa9223a063f11abb2167284a0ffa2dc5c6b9ea740dfe613e1c
NEXT_PUBLIC_LEVO_AGENT_PACKAGE_ID="0x<levo-agent-package-id>"
# Optional testnet RPC override for agent flows (defaults to public Sui testnet fullnode).
LEVO_AGENT_SUI_RPC_URL=""
# Mysten Seal MPC key server (from https://seal-docs.wal.app/Pricing).
# Defaults below point to the Mysten-operated testnet decentralized committee
# (3-of-5 internally, threshold=1 from client perspective). Override for mainnet.
LEVO_AGENT_SEAL_OBJECT_ID="0xb012378c9f3799fb5b1a7083da74a4069e3c3f1c93de0b27212a5799ce1e1e98"
LEVO_AGENT_SEAL_AGGREGATOR_URL="https://seal-aggregator-testnet.mystenlabs.com"
# DeepSeek API key for chat router (Phase D — agent chat surface).
DEEPSEEK_API_KEY="replace-me"
