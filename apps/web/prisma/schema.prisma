generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model XUser {
  xUserId           String        @id @map("x_user_id")
  username          String
  profilePicture    String?       @map("profile_picture")
  isBlueVerified    Boolean       @default(false) @map("is_blue_verified")
  accountStatus     AccountStatus @default(ACTIVE) @map("account_status")
  derivationVersion Int           @default(1) @map("derivation_version")

  // Privy embedded Sui wallet
  privyUserId   String? @unique @map("privy_user_id")
  privyWalletId String? @unique @map("privy_wallet_id")
  suiAddress    String? @unique @map("sui_address")
  suiPublicKey  String? @map("sui_public_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quotes                 PaymentQuote[]
  ledger                 PaymentLedger[]
  earnAccounting         EarnAccounting?
  pendingEarnSettlements PendingEarnSettlement[]
  agentMandates          AgentMandate[]
  agentActions           AgentAction[]
  agentSession           AgentSession?
  userAgents             UserAgent[]

  @@map("x_user")
}

enum AccountStatus {
  ACTIVE
  RENAMED
  SUSPENDED
  DELETED
}

model PaymentQuote {
  id                String        @id @default(cuid())
  senderAddress     String        @map("sender_address")
  recipientType     RecipientType @default(X_HANDLE) @map("recipient_type")
  xUserId           String?       @map("x_user_id")
  usernameAtQuote   String?       @map("username_at_quote")
  derivationVersion Int           @map("derivation_version")
  vaultAddress      String        @map("vault_address")
  coinType          String        @map("coin_type")
  amount            BigInt
  expiresAt         DateTime      @map("expires_at")
  status            QuoteStatus   @default(PENDING)
  hmacToken         String        @map("hmac_token")
  confirmedTxDigest String?       @map("confirmed_tx_digest")
  createdAt         DateTime      @default(now()) @map("created_at")

  xUser XUser? @relation(fields: [xUserId], references: [xUserId])

  @@unique([hmacToken])
  @@index([senderAddress, status])
  @@index([xUserId])
  @@index([expiresAt])
  @@map("payment_quote")
}

enum QuoteStatus {
  PENDING
  CONFIRMED
  EXPIRED
  FAILED
}

model PaymentLedger {
  id            String        @id @default(cuid())
  ledgerSource  LedgerSource  @map("ledger_source")
  txDigest      String        @map("tx_digest")
  sourceIndex   Int           @map("source_index")
  senderAddress String        @map("sender_address")
  recipientType RecipientType @default(X_HANDLE) @map("recipient_type")
  xUserId       String?       @map("x_user_id")
  vaultAddress  String        @map("vault_address")
  coinType      String        @map("coin_type")
  amount        BigInt
  createdAt     DateTime      @default(now()) @map("created_at")

  xUser XUser? @relation(fields: [xUserId], references: [xUserId])

  @@unique([ledgerSource, txDigest, sourceIndex])
  @@index([senderAddress, createdAt(sort: Desc), id(sort: Desc)])
  @@index([xUserId])
  @@map("payment_ledger")
}

enum LedgerSource {
  SEND_CONFIRM
  CONTRACT_EVENT
}

enum RecipientType {
  X_HANDLE
  SUI_ADDRESS
}

model EarnAccounting {
  xUserId                String   @id @map("x_user_id")
  retainedAccountId      String?  @unique @map("retained_account_id")
  lastSettledTxDigest    String?  @map("last_settled_tx_digest")
  rewardDebtPayoutUsdc   String   @default("0") @map("reward_debt_payout_usdc")
  rewardDebtRetainedUsdb String   @default("0") @map("reward_debt_retained_usdb")
  claimedUsdcTotal       BigInt   @default(0) @map("claimed_usdc_total")
  retainedUsdbTotal      BigInt   @default(0) @map("retained_usdb_total")
  lastKnownDepositedUsdc BigInt   @default(0) @map("last_known_deposited_usdc")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  xUser XUser @relation(fields: [xUserId], references: [xUserId])

  @@map("earn_accounting")
}

model EarnGlobalState {
  stableCoinType             String   @id @map("stable_coin_type")
  accPayoutPerShareUsdcE18   String   @default("0") @map("acc_payout_per_share_usdc_e18")
  accRetainedPerShareUsdbE18 String   @default("0") @map("acc_retained_per_share_usdb_e18")
  lastHarvestTxDigest        String?  @map("last_harvest_tx_digest")
  lastHarvestedRewardUsdb    BigInt   @default(0) @map("last_harvested_reward_usdb")
  lastHarvestedPayoutUsdc    BigInt   @default(0) @map("last_harvested_payout_usdc")
  lastHarvestedRetainedUsdb  BigInt   @default(0) @map("last_harvested_retained_usdb")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@map("earn_global_state")
}

model PendingEarn {
  txDigest      String   @id @map("tx_digest")
  xUserId       String   @map("x_user_id")
  action        String
  amount        String?  @map("amount")
  txBytesBase64 String   @map("tx_bytes_base64")
  signatures    String[] @default([])
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([xUserId])
  @@map("pending_earn")
}

model PendingEarnSettlement {
  id                     String   @id @default(cuid())
  xUserId                String   @map("x_user_id")
  action                 String
  stableCoinType         String   @map("stable_coin_type")
  previewToken           String?  @map("preview_token")
  status                 String
  expectedYieldUsdc      BigInt   @default(0) @map("expected_yield_usdc")
  expectedPrincipalUsdc  BigInt   @default(0) @map("expected_principal_usdc")
  yieldTxDigest          String?  @unique @map("yield_tx_digest")
  yieldTxBytesBase64     String?  @map("yield_tx_bytes_base64")
  yieldSignatures        String[] @default([]) @map("yield_signatures")
  principalTxDigest      String?  @unique @map("principal_tx_digest")
  principalTxBytesBase64 String?  @map("principal_tx_bytes_base64")
  principalSignatures    String[] @default([]) @map("principal_signatures")
  settlementSnapshot     Json?    @map("settlement_snapshot")
  lastErrorMessage       String?  @map("last_error_message")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  xUser XUser @relation(fields: [xUserId], references: [xUserId])

  @@index([xUserId])
  @@index([status])
  @@map("pending_earn_settlement")
}

// ---------- Levo Agent (agentic wallet) ----------
// Mirrors `levo-agent` Move package v2 (packages/levo-agent/Published.toml).
// AgentMandate caches the on-chain Mandate object spec for fast UI rendering and
// audit log joins; the source of truth remains the Sui object itself.

model AgentMandate {
  id                String        @id @default(cuid())
  xUserId           String        @map("x_user_id")
  userAgentId       String?       @map("user_agent_id")
  agentAddress      String        @default("") @map("agent_address")
  mandateObjectId   String        @unique @map("mandate_object_id")
  name              String
  actions           Int // u32 bitfield mirror
  coinLimits        Json          @map("coin_limits") // [{coinType, perTxCap, periodCap, periodSpent, periodStartMs}]
  periodMs          BigInt        @map("period_ms")
  allowedTargets    Json          @map("allowed_targets") // string[]
  expiryMs          BigInt        @map("expiry_ms")
  metadata          Json          @default("{}") // VecMap<String, String> mirror
  status            MandateStatus @default(ACTIVE)
  nonce             BigInt        @default(0) // last observed mandate.nonce
  witnessCommit     String?       @map("witness_commit") // hex; null until owner inits
  createdTxDigest   String        @map("created_tx_digest")
  initTxDigest      String?       @map("init_tx_digest") // owner's set_initial_witness tx
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  revokedTxDigest   String?       @map("revoked_tx_digest")
  revokedAt         DateTime?     @map("revoked_at")
  destroyedTxDigest String?       @map("destroyed_tx_digest")
  destroyedAt       DateTime?     @map("destroyed_at")

  xUser              XUser               @relation(fields: [xUserId], references: [xUserId])
  userAgent          UserAgent?          @relation(fields: [userAgentId], references: [id])
  agentActions       AgentAction[]
  agentWitnesses     AgentWitness[]
  agentExecutionJobs AgentExecutionJob[]

  @@index([xUserId, status])
  @@index([userAgentId, status])
  @@index([status, expiryMs])
  @@map("agent_mandate")
}

model UserAgent {
  id                   String          @id @default(cuid())
  xUserId              String          @map("x_user_id")
  agentAddress         String          @map("agent_address")
  label                String
  status               UserAgentStatus @default(ACTIVE)
  isDefault            Boolean         @default(false) @map("is_default")
  custodyMode          UserAgentCustodyMode @default(EXTERNAL_RUNNER) @map("custody_mode")
  hostedEncryptedSeed  Bytes?          @map("hosted_encrypted_seed")
  hostedKeyVersion     String?         @map("hosted_key_version")
  hostedProvisionedAt  DateTime?       @map("hosted_provisioned_at")
  runnerTokenHash      String?         @unique @map("runner_token_hash")
  runnerTokenRotatedAt DateTime?       @map("runner_token_rotated_at")
  lastHeartbeatAt      DateTime?       @map("last_heartbeat_at")
  revokedAt            DateTime?       @map("revoked_at")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  xUser              XUser               @relation(fields: [xUserId], references: [xUserId])
  mandates           AgentMandate[]
  agentExecutionJobs AgentExecutionJob[]

  @@unique([xUserId, agentAddress])
  @@index([xUserId, status, isDefault])
  @@index([xUserId, custodyMode, status, isDefault])
  @@map("user_agent")
}

enum UserAgentStatus {
  ACTIVE
  REVOKED
}

enum UserAgentCustodyMode {
  EXTERNAL_RUNNER
  HOSTED
}

// One row per pre-generated witness chain step. Witness preimage is NOT stored
// (only the Seal ciphertext + the action context bound to it). At execution time
// the agent fetches `encrypted_object`, asks Seal to decrypt it (which dry-runs
// `seal_approve` against the live mandate), and submits the resulting witness
// preimage through `consume_witness`.
model AgentWitness {
  id               String    @id @default(cuid())
  mandateId        String    @map("mandate_id")
  chainIndex       Int       @map("chain_index") // 0 = first consumed step
  actionType       Int       @map("action_type") // u32 single-bit
  coinType         String    @map("coin_type") // fully qualified Move type
  amount           String // u64 decimal string
  target           String
  currentCommit    String    @map("current_commit") // hex; on-chain witness_commit when this step is consumed
  nextCommit       String    @map("next_commit") // hex; what consume rotates to
  approvalIdentity String    @map("approval_identity") // hex; Seal blob id (derive_approval_id)
  encryptedObject  Bytes     @map("encrypted_object") // Seal ciphertext
  consumed         Boolean   @default(false)
  consumedAt       DateTime? @map("consumed_at")
  consumedTxDigest String?   @map("consumed_tx_digest")
  createdAt        DateTime  @default(now()) @map("created_at")

  mandate      AgentMandate       @relation(fields: [mandateId], references: [id])
  executionJob AgentExecutionJob?

  @@unique([mandateId, chainIndex])
  @@index([mandateId, consumed, chainIndex])
  @@map("agent_witness")
}

enum MandateStatus {
  ACTIVE
  REVOKED
  EXPIRED
  PAUSED_BY_USER
  LEGACY_PAUSED
  DESTROYED
}

model AgentExecutionJob {
  id                String                  @id @default(cuid())
  userAgentId       String                  @map("user_agent_id")
  mandateId         String                  @map("mandate_id")
  witnessId         String?                 @unique @map("witness_id")
  trigger           ActionTrigger
  status            AgentExecutionJobStatus @default(QUEUED)
  dueAt             DateTime                @default(now()) @map("due_at")
  claimedAt         DateTime?               @map("claimed_at")
  claimExpiresAt    DateTime?               @map("claim_expires_at")
  lockedByTokenHash String?                 @map("locked_by_token_hash")
  txDigest          String?                 @map("tx_digest")
  result            Json?
  errorReason       String?                 @map("error_reason")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  userAgent UserAgent     @relation(fields: [userAgentId], references: [id])
  mandate   AgentMandate  @relation(fields: [mandateId], references: [id])
  witness   AgentWitness? @relation(fields: [witnessId], references: [id])

  @@index([userAgentId, status, dueAt])
  @@index([mandateId, status])
  @@index([status, dueAt])
  @@map("agent_execution_job")
}

enum AgentExecutionJobStatus {
  QUEUED
  CLAIMED
  CONFIRMED
  FAILED
  CANCELLED
}

model AgentAction {
  id           String        @id @default(cuid())
  mandateId    String        @map("mandate_id")
  xUserId      String        @map("x_user_id")
  actionType   Int           @map("action_type") // u32 single-bit
  coinType     String        @map("coin_type")
  amount       String // u64 as decimal string
  target       String
  status       ActionStatus
  txDigest     String?       @map("tx_digest")
  trigger      ActionTrigger
  sealApproved Boolean       @map("seal_approved")
  errorReason  String?       @map("error_reason")
  // Witness chain fields (from WitnessConsumed event after on-chain confirmation).
  nonceAfter   BigInt?       @map("nonce_after")
  commitBefore String?       @map("commit_before")
  commitAfter  String?       @map("commit_after")
  createdAt    DateTime      @default(now()) @map("created_at")
  confirmedAt  DateTime?     @map("confirmed_at")

  mandate AgentMandate @relation(fields: [mandateId], references: [id])
  xUser   XUser        @relation(fields: [xUserId], references: [xUserId])

  @@index([xUserId, createdAt(sort: Desc)])
  @@index([mandateId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("agent_action")
}

enum ActionStatus {
  PENDING
  CONFIRMED
  FAILED
  BLOCKED_BY_SEAL
}

enum ActionTrigger {
  CHAT
  SCHEDULED
  EVENT
}

model AgentSession {
  xUserId   String   @id @map("x_user_id")
  messages  Json     @default("[]")
  paused    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  xUser XUser @relation(fields: [xUserId], references: [xUserId])

  @@map("agent_session")
}
